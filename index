<!DOCTYPE html>
<html lang="sv">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blueprint: Energigemenskap i Sverige</title>
<style>
  :root {
    --green-dark: #1a5c38;
    --green-mid: #2d8653;
    --green-light: #4caf80;
    --green-pale: #e8f5ee;
    --yellow: #f0c040;
    --orange: #e87722;
    --blue: #1a3f6f;
    --blue-light: #e8f0fa;
    --purple: #6a3fa0;
    --purple-light: #f3eeff;
    --purple-mid: #9b59d4;
    --gray: #4a5568;
    --gray-light: #f7f7f7;
    --white: #ffffff;
    --shadow: 0 2px 12px rgba(0,0,0,0.10);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', Arial, sans-serif; background: #f0f4f0; color: #1a2a1a; }

  nav {
    background: var(--green-dark);
    color: white;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }
  nav .logo { font-size: 1.2rem; font-weight: 700; padding: 1rem 1rem 1rem 0; border-right: 1px solid rgba(255,255,255,0.3); margin-right: 0.5rem; }
  nav button {
    background: none; border: none; color: rgba(255,255,255,0.8);
    font-size: 0.85rem; padding: 1rem 0.75rem; cursor: pointer;
    border-bottom: 3px solid transparent; transition: all 0.2s;
    white-space: nowrap;
  }
  nav button:hover, nav button.active { color: white; border-bottom-color: var(--yellow); }

  .page { display: none; padding: 2rem; max-width: 1200px; margin: 0 auto; }
  .page.active { display: block; }

  h1 { font-size: 2rem; color: var(--green-dark); margin-bottom: 0.5rem; }
  h2 { font-size: 1.4rem; color: var(--green-dark); margin-bottom: 1rem; margin-top: 2rem; }
  h3 { font-size: 1.05rem; color: var(--green-dark); margin-bottom: 0.5rem; }
  p { line-height: 1.6; color: var(--gray); margin-bottom: 0.75rem; }
  .subtitle { color: var(--gray); font-size: 1rem; margin-bottom: 2rem; }

  .hero {
    background: linear-gradient(135deg, var(--green-dark) 0%, var(--green-mid) 100%);
    color: white; border-radius: 16px; padding: 3rem 2.5rem;
    margin-bottom: 2rem; position: relative; overflow: hidden;
  }
  .hero::after { content: '⚡'; position: absolute; right: 2rem; top: 50%; transform: translateY(-50%); font-size: 8rem; opacity: 0.08; }
  .hero h1 { color: white; font-size: 2.2rem; }
  .hero p { color: rgba(255,255,255,0.85); font-size: 1.05rem; }
  .hero .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .tag { background: rgba(255,255,255,0.15); color: white; padding: 0.3rem 0.9rem; border-radius: 20px; font-size: 0.8rem; border: 1px solid rgba(255,255,255,0.3); }

  .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem; margin-bottom: 2rem; }
  .card { background: white; border-radius: 12px; padding: 1.5rem; box-shadow: var(--shadow); border-left: 4px solid var(--green-mid); transition: transform 0.2s, box-shadow 0.2s; }
  .card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.13); }
  .card .icon { font-size: 2rem; margin-bottom: 0.75rem; }
  .card h3 { color: var(--green-dark); margin-bottom: 0.4rem; }
  .card p { font-size: 0.9rem; color: var(--gray); }
  .card.warn { border-left-color: var(--orange); }
  .card.info { border-left-color: var(--blue); }
  .card.purple { border-left-color: var(--purple); }

  /* PROCESS TIMELINE */
  .timeline { position: relative; padding-left: 2rem; }
  .timeline::before { content: ''; position: absolute; left: 0.6rem; top: 0; bottom: 0; width: 3px; background: linear-gradient(to bottom, var(--green-dark), var(--green-light)); border-radius: 2px; }
  .phase { position: relative; margin-bottom: 2rem; background: white; border-radius: 12px; padding: 1.5rem 1.5rem 1.5rem 1.75rem; box-shadow: var(--shadow); border-right: 4px solid transparent; transition: border-color 0.2s; }
  .phase:hover { border-right-color: var(--green-light); }
  .phase::before { content: attr(data-num); position: absolute; left: -2.3rem; top: 1.2rem; width: 2rem; height: 2rem; border-radius: 50%; background: var(--green-dark); color: white; font-weight: 700; font-size: 0.85rem; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 6px rgba(0,0,0,0.2); }
  .phase-header { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
  .phase h3 { font-size: 1.15rem; color: var(--green-dark); }
  .phase-time { background: var(--green-pale); color: var(--green-dark); font-size: 0.8rem; padding: 0.2rem 0.7rem; border-radius: 20px; font-weight: 600; }
  .phase-desc { color: var(--gray); font-size: 0.95rem; margin-bottom: 1rem; }
  .actor-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; }
  .actor-chip { display: flex; align-items: center; gap: 0.4rem; background: var(--green-pale); border: 1px solid #b2d8c4; padding: 0.3rem 0.75rem; border-radius: 20px; font-size: 0.82rem; color: var(--green-dark); }
  .actor-chip.gov { background: #e8f0fa; border-color: #b2c8e8; color: var(--blue); }
  .actor-chip.tech { background: #fff3e0; border-color: #f0c88a; color: #7a4200; }
  .actor-chip.fin { background: #fce8f0; border-color: #e8a8c8; color: #6d1a3a; }
  .checklist { list-style: none; margin-top: 0.5rem; }
  .checklist li { padding: 0.3rem 0; font-size: 0.9rem; color: var(--gray); display: flex; gap: 0.5rem; align-items: flex-start; }
  .checklist li::before { content: '☐'; font-size: 1rem; color: var(--green-mid); flex-shrink: 0; margin-top: 0.05rem; }

  /* ACTORS */
  .actor-table { width: 100%; border-collapse: collapse; background: white; border-radius: 12px; overflow: hidden; box-shadow: var(--shadow); }
  .actor-table th { background: var(--green-dark); color: white; padding: 0.75rem 1rem; text-align: left; font-size: 0.9rem; }
  .actor-table td { padding: 0.75rem 1rem; border-bottom: 1px solid #e8f0e8; font-size: 0.9rem; vertical-align: top; }
  .actor-table tr:last-child td { border-bottom: none; }
  .actor-table tr:hover td { background: var(--green-pale); }
  .phase-dots { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .dot { width: 22px; height: 22px; border-radius: 50%; background: #ddd; font-size: 0.65rem; font-weight: 700; display: flex; align-items: center; justify-content: center; color: white; }
  .dot.active { background: var(--green-mid); }
  .dot.key { background: var(--green-dark); }

  /* MODELS */
  .model-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
  .model-card { background: white; border-radius: 12px; box-shadow: var(--shadow); padding: 1.5rem; }
  .model-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--green-mid); margin-bottom: 0.5rem; }
  .model-card h3 { color: var(--green-dark); margin-bottom: 0.5rem; }
  .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-top: 0.75rem; }
  .pro, .con { padding: 0.5rem; border-radius: 6px; font-size: 0.8rem; }
  .pro { background: #e8f5ee; color: #1a5c38; }
  .con { background: #fff3e0; color: #7a4200; }
  .pro::before { content: '✓ '; font-weight: 700; }
  .con::before { content: '⚠ '; font-weight: 700; }

  /* THEMES */
  .theme-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }
  .theme-card { background: white; border-radius: 12px; box-shadow: var(--shadow); overflow: hidden; }
  .theme-card .theme-head { padding: 1.25rem 1.5rem; color: white; }
  .theme-card .theme-body { padding: 1.25rem 1.5rem; }
  .theme-card .theme-body ul { padding-left: 1.2rem; }
  .theme-card .theme-body li { font-size: 0.9rem; color: var(--gray); margin-bottom: 0.4rem; line-height: 1.5; }
  .gap-box { margin-top: 0.75rem; background: #fff8e8; border: 1px solid #f0d070; border-radius: 8px; padding: 0.75rem; font-size: 0.85rem; color: #7a5500; }
  .gap-box strong { color: #5a3a00; }


  /* ── GOVERNANCE COMPLICATIONS ── */
  .gov-hero2{background:linear-gradient(135deg,#1a0a2e 0%,#3d1a6a 60%,#5a2d9a 100%);padding:2rem 2rem 1.75rem;border-radius:12px;margin-bottom:1.5rem;position:relative;overflow:hidden}
  .gov-hero2::before{content:'';position:absolute;top:-40px;right:-40px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.03)}
  .gov-hero2 h2{color:white;font-size:1.6rem;margin-bottom:.4rem}
  .gov-hero2 p{color:rgba(255,255,255,.75);font-size:.9rem;line-height:1.6;margin-bottom:1.1rem}
  .cpills{display:flex;flex-wrap:wrap;gap:.45rem}
  .cpill{padding:.3rem .8rem;border-radius:18px;font-size:.76rem;font-weight:600;cursor:pointer;border:1px solid rgba(255,255,255,.18);color:white;transition:all .2s;background:rgba(255,255,255,.1)}
  .cpill:hover,.cpill.active{background:rgba(255,255,255,.25);box-shadow:0 0 0 2px rgba(255,255,255,.4)}
  .complication{background:white;border-radius:12px;box-shadow:var(--shadow);margin-bottom:1.5rem;overflow:hidden;display:none;animation:fadeIn .25s ease}
  .complication.vis{display:block}
  @keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
  .comp-hd{padding:1.1rem 1.5rem;display:flex;align-items:flex-start;gap:.85rem;border-bottom:1px solid #f0eaf8}
  .comp-icon{font-size:1.75rem;flex-shrink:0;margin-top:.05rem}
  .comp-hd h3{font-size:1.05rem;font-weight:700;margin-bottom:.2rem}
  .comp-hd p{font-size:.84rem;color:var(--gray);line-height:1.45;margin:0}
  .comp-badge2{margin-left:auto;flex-shrink:0;padding:.2rem .65rem;border-radius:12px;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;white-space:nowrap;align-self:flex-start}
  .comp-bd{padding:1.25rem 1.5rem}
  .scenario{background:#fff5f5;border-left:4px solid #e05050;border-radius:0 8px 8px 0;padding:.75rem .9rem;margin-bottom:1.1rem;font-size:.84rem}
  .scenario strong{color:#a02020;display:block;margin-bottom:.2rem;font-size:.75rem;text-transform:uppercase;letter-spacing:.05em}
  .dtree-title{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#7c45c8;margin:.9rem 0 .55rem}
  .dnode{display:flex;gap:.5rem;align-items:flex-start;margin-bottom:.4rem;padding:.55rem .75rem;border-radius:7px;font-size:.83rem}
  .dn-q{background:#f0eaff;color:#3a1a6a}
  .dn-y{background:#e8f5ee;color:#1a5c38}
  .dn-w{background:#fff5f5;color:#a02020}
  .dn-arrow{margin:.1rem 0 .4rem 1.2rem;font-size:.72rem;color:#9a8ab8;display:flex;gap:1.25rem}
  .gov-table{width:100%;border-collapse:collapse;font-size:.82rem;margin:0 0 1.1rem}
  .gov-table th{padding:.5rem .75rem;text-align:left;background:#f0eaff;color:#3a1a6a;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em}
  .gov-table td{padding:.55rem .75rem;border-bottom:1px solid #f5f0ff;vertical-align:top;line-height:1.4}
  .gov-table tr:last-child td{border-bottom:none}
  .gov-table tr:hover td{background:#faf8ff}
  .risk-chip{display:inline-block;padding:.12rem .45rem;border-radius:5px;font-size:.7rem;font-weight:700}
  .r-lo{background:#e8f5ee;color:#1a5c38}.r-me{background:#fff3e0;color:#7a4200}.r-hi{background:#fff5f5;color:#c03030}
  .power-grid{display:grid;grid-template-columns:1fr 1fr;gap:.85rem;margin-bottom:1.1rem}
  .power-side{border-radius:9px;padding:.9rem 1rem}
  .power-side h4{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:.55rem}
  .power-dom{background:#fff0f0;border:1px solid #f0c0c0}.power-dom h4{color:#a02020}
  .power-pro{background:#f0f0ff;border:1px solid #c0c0f0}.power-pro h4{color:#2020a0}
  .power-item{font-size:.8rem;padding:.2rem 0;color:var(--gray);display:flex;gap:.35rem}
  .check-grid2{display:grid;grid-template-columns:1fr 1fr;gap:.85rem;margin-bottom:1.1rem}
  .check-box2{background:#faf8ff;border:1px solid #e0d0f8;border-radius:9px;padding:.9rem 1rem}
  .check-box2 h4{font-size:.78rem;font-weight:700;color:#3a1a6a;margin-bottom:.55rem;padding-bottom:.35rem;border-bottom:1px solid #e8e0f8}
  .chk{display:flex;gap:.45rem;padding:.22rem 0;font-size:.8rem;color:var(--gray);cursor:pointer;align-items:flex-start}
  .chk input{margin-top:.12rem;accent-color:#5a2d9a;cursor:pointer;flex-shrink:0}
  .gdpr-wrap{background:white;border:1px solid #e0d0f8;border-radius:9px;overflow:hidden;margin-bottom:1.1rem;font-size:.82rem}
  .gdpr-hd{display:grid;grid-template-columns:170px 1fr 110px;gap:.5rem;padding:.45rem .75rem;background:#f0eaff}
  .gdpr-hd div{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:#3a1a6a}
  .gdpr-row2{display:grid;grid-template-columns:170px 1fr 110px;gap:.5rem;padding:.6rem .75rem;border-top:1px solid #f0eaf8;align-items:start}
  .lb{font-size:.7rem;padding:.15rem .45rem;border-radius:5px;font-weight:600;display:inline-block}
  .lb-c{background:#e8f5ee;color:#1a5c38}.lb-a{background:#e8f0fa;color:#1a3f6f}.lb-i{background:#fff3e0;color:#7a4200}
  .info-box2{background:#f0eaff;border:1px solid #c8a8f0;border-radius:9px;padding:.75rem 1rem;font-size:.83rem;color:#3a1a6a;margin-bottom:1rem}
  .warn-box2{background:#fff8e0;border:1px solid #e8c840;border-radius:9px;padding:.75rem 1rem;font-size:.83rem;color:#7a5800;margin-bottom:1rem}
  @media(max-width:640px){.power-grid,.check-grid2{grid-template-columns:1fr}.gdpr-hd,.gdpr-row2{grid-template-columns:1fr}}
  /* ── GOVERNANCE ── */
  .gov-hero {
    background: linear-gradient(135deg, #2a1a3a 0%, #4a2a70 100%);
    color: white; border-radius: 16px; padding: 2.5rem 2.5rem;
    margin-bottom: 2rem; position: relative; overflow: hidden;
  }
  .gov-hero::after { content: '🏛️'; position: absolute; right: 2rem; top: 50%; transform: translateY(-50%); font-size: 7rem; opacity: 0.1; }
  .gov-hero h1 { color: white; font-size: 2rem; }
  .gov-hero p { color: rgba(255,255,255,0.82); font-size: 1rem; }
  .gov-hero .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1.25rem; }
  .gov-tag { background: rgba(255,255,255,0.13); color: white; padding: 0.3rem 0.85rem; border-radius: 20px; font-size: 0.78rem; border: 1px solid rgba(255,255,255,0.25); cursor: pointer; transition: background 0.2s; }
  .gov-tag:hover { background: rgba(255,255,255,0.22); }

  /* Gov section tabs */
  .gov-tabs { display: flex; gap: 0; border-bottom: 2px solid #e0d0f0; margin-bottom: 2rem; flex-wrap: wrap; }
  .gov-tab { padding: 0.7rem 1.1rem; font-size: 0.85rem; font-weight: 600; cursor: pointer; border: none; background: none; color: #8a6aa0; border-bottom: 3px solid transparent; margin-bottom: -2px; transition: all 0.2s; white-space: nowrap; }
  .gov-tab:hover { color: var(--purple); }
  .gov-tab.active { color: var(--purple); border-bottom-color: var(--purple); }

  .gov-section { display: none; }
  .gov-section.active { display: block; }

  /* Org form cards */
  .org-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.1rem; margin-bottom: 1.5rem; }
  .org-card { background: white; border-radius: 12px; box-shadow: var(--shadow); padding: 1.4rem; border-top: 4px solid #ddd; position: relative; }
  .org-card.recommended { border-top-color: var(--purple); }
  .org-card .rec-badge { position: absolute; top: -1px; right: 1rem; background: var(--purple); color: white; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; padding: 0.2rem 0.65rem; border-radius: 0 0 6px 6px; }
  .org-card h3 { color: #3a1a5a; margin-bottom: 0.5rem; font-size: 1rem; }
  .org-card p { font-size: 0.86rem; color: var(--gray); margin: 0; }
  .org-card .org-pros { margin-top: 0.75rem; display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .org-pro { background: #f0eaff; color: #5a2a90; font-size: 0.75rem; padding: 0.2rem 0.6rem; border-radius: 10px; }
  .org-con { background: #fff3e0; color: #7a4200; font-size: 0.75rem; padding: 0.2rem 0.6rem; border-radius: 10px; }

  /* Role cards */
  .role-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.1rem; }
  .role-card { background: white; border-radius: 12px; box-shadow: var(--shadow); padding: 1.35rem; border-left: 4px solid var(--purple); }
  .role-card .role-icon { font-size: 1.75rem; margin-bottom: 0.5rem; }
  .role-card h3 { color: #3a1a5a; font-size: 0.98rem; margin-bottom: 0.4rem; }
  .role-card p { font-size: 0.85rem; color: var(--gray); margin: 0; }
  .role-card .role-warn { margin-top: 0.6rem; font-size: 0.78rem; color: #7a4200; background: #fff3e0; border-radius: 6px; padding: 0.35rem 0.6rem; }

  /* Decision cards */
  .decision-list { display: flex; flex-direction: column; gap: 1rem; }
  .decision-card { background: white; border-radius: 12px; box-shadow: var(--shadow); padding: 1.35rem 1.5rem; display: flex; gap: 1.25rem; align-items: flex-start; }
  .decision-num { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #4a2a70, #7a3ab0); color: white; font-weight: 700; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .decision-body h3 { color: #3a1a5a; font-size: 0.98rem; margin-bottom: 0.3rem; }
  .decision-body p { font-size: 0.86rem; color: var(--gray); margin: 0; line-height: 1.55; }
  .decision-body .decision-detail { margin-top: 0.5rem; font-size: 0.82rem; color: #8a6aa0; }

  /* Stadge checklist */
  .stadge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .stadge-box { background: white; border-radius: 12px; box-shadow: var(--shadow); padding: 1.35rem; }
  .stadge-box h3 { font-size: 0.95rem; color: #3a1a5a; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid #e0d0f0; }
  .stadge-item { display: flex; gap: 0.5rem; padding: 0.3rem 0; font-size: 0.85rem; color: var(--gray); }
  .stadge-item::before { content: '☐'; color: var(--purple-mid); flex-shrink: 0; }
  .stadge-item.done::before { content: '✓'; color: var(--purple); font-weight: 700; }

  /* Conflict cards */
  .conflict-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.1rem; }
  .conflict-card { background: white; border-radius: 12px; box-shadow: var(--shadow); padding: 1.35rem; border-top: 3px solid #e0d0f0; }
  .conflict-card.urgent { border-top-color: var(--orange); }
  .conflict-card h3 { font-size: 0.95rem; color: #3a1a5a; margin-bottom: 0.4rem; }
  .conflict-card p { font-size: 0.85rem; color: var(--gray); margin: 0; line-height: 1.55; }
  .conflict-tip { margin-top: 0.6rem; font-size: 0.78rem; color: #5a2a90; background: #f3eeff; border-radius: 6px; padding: 0.35rem 0.65rem; }

  /* Gov phase bar */
  .gov-phase-bar { background: linear-gradient(90deg, #f3eeff, #e8f0fa); border: 1px solid #d0b8f0; border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; }
  .gov-phase-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.83rem; }
  .gov-phase-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  .page-footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #dde8dd; color: #888; font-size: 0.82rem; text-align: center; }

  @media (max-width: 640px) {
    .page { padding: 1rem; }
    nav { padding: 0 0.5rem; }
    .stadge-grid { grid-template-columns: 1fr; }
    .hero, .gov-hero { padding: 2rem 1.5rem; }
  }
</style>
</head>
<body>

<!-- ═══ ACCESS GATE ═══ -->
<div id="access-gate" style="position:fixed;inset:0;background:linear-gradient(135deg,#0a1a2a 0%,#0d3050 60%,#0a2a1a 100%);display:flex;align-items:center;justify-content:center;z-index:99999;font-family:inherit">
  <div style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.15);border-radius:20px;padding:2.5rem 2.5rem 2rem;width:100%;max-width:380px;text-align:center;backdrop-filter:blur(12px)">
