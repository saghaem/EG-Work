  <!-- ══ TAB 5: GOVERNANCE ══ -->
  <div class="brf-tab" id="brft-panel-4">
    <p style="color:#5a7090;font-size:.88rem;margin-bottom:1.25rem">Hur en BRF-styrelse fattar, förankrar och följer upp beslut om energiinvesteringar.</p>

